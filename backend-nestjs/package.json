{
  "name": "app-nestjs",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start:debug": "nest start --debug --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node --files --require tsconfig-paths/register ./node_modules/typeorm/cli",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=dev nest start --watch",
    "db:backup": "ts-node src/database/scripts/backup-migrations.ts",
    "db:init": "./src/database/scripts/init-migrations.sh",
    "migration:generate": "npm run typeorm -- migration:generate -d src/database/data-source.ts",
    "db:generate": "./src/database/scripts/generate-migration.sh",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source.ts",
    "db:status": "npm run typeorm -- migration:show -d src/database/data-source.ts",
    "db:run": "./src/database/scripts/run-migration.sh",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/data-source.ts",
    "db:rollback": "./src/database/scripts/rollback-migration.sh",
    "db:clear": "./src/database/scripts/clear-migrations.sh",
    "build:prod": "cross-env NODE_ENV=prod nest build",
    "start:prod": "cross-env NODE_ENV=prod node dist/main",
    "db:run:prod": "cross-env NODE_ENV=prod npm run typeorm -- migration:run -d dist/database/data-source.js",
    "db:rollback:prod": "cross-env NODE_ENV=prod npm run typeorm -- migration:revert -d dist/database/data-source.js",
    "db:backup:prod": "node dist/database/scripts/backup-migrations.js --prod",
    "build:stage": "cross-env NODE_ENV=stage nest build",
    "start:stage": "cross-env NODE_ENV=stage node dist/main",
    "db:run:stage": "cross-env NODE_ENV=stage npm run typeorm -- migration:run -d dist/database/data-source.js",
    "db:rollback:stage": "cross-env NODE_ENV=stage npm run typeorm -- migration:revert -d dist/database/data-source.js",
    "db:backup:stage": "node dist/database/scripts/backup-migrations.js --stage"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.2.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@bull-board/api": "^6.13.0",
    "@bull-board/express": "^6.13.0",
    "@nestjs/bull": "^11.0.3",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/typeorm": "^11.0.0",
    "@types/mongoose": "^5.11.96",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.61.0",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.1.0",
    "google-auth-library": "^10.6.2",
    "google-libphonenumber": "^3.2.43",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.16.1",
    "multer": "^2.0.2",
    "mysql2": "^3.14.1",
    "node-rsa": "^1.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "raw-body": "^3.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "semver": "^7.7.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.8",
    "@types/raw-body": "^2.1.4",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
